# Example environment variables derived from config/default.yaml
# Copy this to .env and fill real values (do NOT commit secrets)

NODE_ENV=development
PORT=3002

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Service
ENCRYPT_KEY=your_encrypt_key
BASE_URL=api
DOCS_BASE_URL=api/docs
API_VERSION=1.0
ENABLE_CRONJOB=enable
FRONTEND_BASE_URL=http://localhost:3000
BACKEND_BASE_URL=http://localhost:3002/api/v1

# Logger
LOGGER_LEVEL=debug
AUTO_LOGGING=true

# AWS
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-1
AWS_BUCKET=your-bucket
AWS_API_VERSION=2023-11-01
AWS_PATH=hpg
AWS_ENABLE_UPLOAD_EXCEL=enable1

# CDN
CDN_BASE_URL=https://cdn

# SMS
SMS_ENDPOINT=https://vn
SMS_PARTNER_CODE=950310
SMS_SECRET_KEY=
SMS_KEYWORD=HAC
SMS_BRAND_NAME="HOAPHAT HAC"
SMS_ENABLE_SMS=false

# RabbitMQ
RABBITMQ_URI=amqp://user:pass@localhost:5672

# Mail
MAIL_HOST=smtp.gmail.com
MAIL_USER=you@example.com
MAIL_PASS=your_smtp_password
MAIL_PORT=587
MAIL_ENABLE_SEND_MAIL=enable

# Firebase
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
FIREBASE_CLIENT_EMAIL=your-client-email@project.iam.gserviceaccount.com
FIREBASE_DATABASE_URL=your-firebase-db-url
FIREBASE_ENABLE_SEND_NOTIFICATION=enable

# Country API
COUNTRY_API_KEY=your_country_api_key
COUNTRY_API_LIST=https://api.countrystatecity.in/v1/countries
COUNTRY_API_DETAIL=https://api.countrystatecity.in/v1/countries/[ciso]
COUNTRY_API_STATE_BY_COUNTRY=https://api.countrystatecity.in/v1/countries/[ciso]/states
COUNTRY_API_STATE_DETAIL=https://api.countrystatecity.in/v1/countries/[country_code]/states/[state_code]
COUNTRY_API_PUBLIC_LIST_COUNTRY=https://raw.githubusercontent.com/dr5hn/countries-states-cities-database/master/countries.json
COUNTRY_API_GET_CITIES_BY_STATES=https://api.countrystatecity.in/v1/countries/[country_code]/states/[state_code]/cities

# Apple / Google / Social
APPLE_TEAM_ID=
APPLE_CLIENT_ID=
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
APPLE_KEY_IDENTIFIER=
APPLE_REDIRECT_URI=

GOOGLE_WEB_CLIENT_ID=
GOOGLE_WEB_CLIENT_SECRET=
ANDROID_CLIENT_ID=
ANDROID_CLIENT_ID_PROD=
GOOGLE_PROJECT_ID=
GOOGLE_CERT_PATH=secrets/google-certs.json
GOOGLE_STORAGE_BUCKET=
GOOGLE_STORAGE_ENDPOINT=https://storage.googleapis.com

# Twitter
TWITTER_API_KEY=
TWITTER_API_SECRET_KEY=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
TWITTER_API_ENDPOINT=https://api.twitter.com

# Facebook
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_GRAPH_API_ENDPOINT=https://graph.facebook.com

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISH_KEY=

# Paypal / Braintree
BRAINTREE_ACCESS_TOKEN=

# Shipment (example)
SHIPMENT_FANCHO_STREET_ADDRESS=2115 Kern St. 102M
SHIPMENT_FANCHO_CITY=Fresno
SHIPMENT_FANCHO_STATE_CODE=CA
SHIPMENT_FANCHO_STATE_NAME=California
SHIPMENT_FANCHO_COUNTRY_CODE=US
SHIPMENT_FANCHO_COUNTRY_NAME="United States"
SHIPMENT_FANCHO_POSTAL_CODE=93721
SHIPMENT_FANCHO_PHONE=7735625452

# FedEx
FEDEX_ACCOUNT_NUMBER=
FEDEX_CLIENT_ID=
FEDEX_SECRET_KEY=
FEDEX_API_ENDPOINT=https://apis-sandbox.fedex.com
FEDEX_WEBHOOK_SECRET_TOKEN=
FEDEX_TRACKING_BASE_URL=https://www.fedex.com/fedextrack

# USPS
USPS_CONSUMER_KEY=
USPS_CONSUMER_SECRET=
USPS_API_ENDPOINT=https://api-cat.usps.com
USPS_CRID=
USPS_MID=
USPS_MANIFEST_MID=
USPS_ACCOUNT_TYPE=EPS
USPS_ACCOUNT_NUMBER=
USPS_TRACKING_BASE_URL=https://tools.usps.com/go/TrackConfirmAction

# TaxCloud
TAX_BASE_API=https://api.taxcloud.net/1.0/TaxCloud
TAX_API_KEY=
TAX_API_LOGIN_ID=
TAX_TIC=
